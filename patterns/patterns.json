{
  "sql_exceptions": {
    "base": {
      "separator": "^(?P<time>\\d{2}:\\d{2}:\\d{2})"
    },
    "patterns": {
      "sql_exception": "(?s)exception on sql statement:\\s*(?P<sql_query>.+?)\\s*\\(transformed to.*?java\\.sql\\.[^:]+:\\s*(?P<error_details>.*?)(?:\\s+for statement|$).*?Caused by:\\s*java\\.sql\\.[^:]+:\\s*(?P<caused_by>[^\\n]*)",
      "check_failed_for_db": "(?s)check failed for alias\\s+(?P<check_failed_for>'.*?').*?Caused by:\\s*java\\.net\\.[^:]+:\\s*(?P<caused_by>[^\\n]*)"
    }
  },
  "db_pool_size_exceeded": {
    "base": {
      "separator": "^(?P<time>\\d{2}:\\d{2}:\\d{2})"
    },
    "patterns": {
      "default": "(?s)alias\\s+(?P<alias>\\w+):\\s+pool size already exceeded\\s+(?P<exceeded_pool_size_by>\\d+)\\.\\s+Total connections:\\s+(?P<total_connections>\\d+)"
    }
  },
  "ftp_per_profile": {
    "base": {
      "separator": "^(?P<time>\\d{2}:\\d{2}:\\d{2})"
    },
    "patterns": {
      "default": "Job:\\s*(?P<Job>\\d+)\\s+\\[(?P<Profile>[^\\]]+)\\].*?Start to send response.*?by FTP.*?Comm\\.Channel=(?P<Channel>[^,]+).*?file=(?P<File>[^\\s\\)]+)"
    }
  },
  "http_requests_jasperserver": {
    "base": {
      "separator": "^.*?\\[(?P<time>\\d{2}/\\w{3}/\\d{4}:\\d{2}:\\d{2}:\\d{2})"
    },
    "patterns": {
      "default": "^(?P<ip>\\S+)\\s(?P<logname>\\S+)\\s(?P<user>\\S+)\\s\\[(?P<timestamp>\\d{2}/\\w{3}/\\d{4}:\\d{2}:\\d{2}:\\d{2})\\s(?P<timezone>[^\\]]+)\\]\\s\"(?P<method>[A-Z]+)\\s(?P<path>\\S+)\\sHTTP\\/(?P<protocol>\\d\\.\\d)\"\\s(?P<status>\\d{3})\\s(?P<size>\\d+)\\s(?P<duration>\\d+)$"
    }
  },
  "catalina_out_jasperserver": {
    "base": {
      "separator": "^(\\d{2}-\\w{3}-\\d{4}|\\d{4}-\\d{2}-\\d{2}T)"
    },
    "patterns": {
      "catalina_out_severe": "(?P<time>\\d{2}-\\w{3}-\\d{4}\\s[\\d:.]+)\\s+(?P<Severity>SEVERE)\\s+\\[(?P<Header>[^\\]]+)\\]\\s+(?P<Message>[^\\r\\n]+)(?:[\\s\\S]*?Caused by:\\s+(?P<Cause>[^\\r\\n]+))?",
      "catalina_out_error": "(?P<time>\\d{4}-\\d{2}-\\d{2}T[\\d:,]+)\\s+(?P<Severity>ERROR)\\s+(?P<Header>[\\w,:-]+)\\s+-\\s+(?P<Message>[^\\r\\n]+)(?:[\\s\\S]*?Caused by:\\s+(?P<Cause>[^\\r\\n]+))?"
    }
  }
}
