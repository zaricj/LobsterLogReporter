{
  "sql_exceptions": {
    "base": {
      "header": "^(?P<time>\\d{2}:\\d{2}:\\d{2})\\s+(?P<source>[A-Z:()0-9]+)"
    },
    "patterns": {
      "sql_query": "exception on sql statement:\\s*(?P<sql_query>.+?)(?=\\s*\\(transformed to)",
      "error_details": "java\\.sql\\.[^:]+:\\s*(?P<error_details>[^\n]*)",
      "parameter_error": "Error while trying to set parameter @(?P<parameter>[^@]+)@.*\\(value: '(?P<value>[^']+)'\\)"
    }
  }
}